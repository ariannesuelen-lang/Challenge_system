def pagina_meu_perfil():
    st.subheader("👤 Meu Perfil")

    dados = get(f"/usuarios/{user_id()}")
    if not dados:
        st.error("Não foi possível carregar os dados do perfil.")
        return

    with st.form("form_perfil"):
        nome = st.text_input("Nome completo", value=dados["nome"])
        email = st.text_input("Email", value=dados["email"])
        nova_senha = st.text_input(
            "Nova senha (deixe em branco para manter a atual)",
            type="password",
        )
        submitted = st.form_submit_button("💾 Salvar alterações")

    validar_email_field(email)
    validar_senha_field(nova_senha)

    if submitted:
        payload = {"nome": nome, "email": email, "tipo_usuario": dados["tipo_usuario"]}
        if nova_senha:
            payload["senha"] = nova_senha

        res = put(f"/usuarios/{user_id()}", payload)
        if res and res.status_code == 200:
            st.session_state.usuario["nome"] = nome
            st.session_state.usuario["email"] = email
            st.success("Perfil atualizado com sucesso!")
            st.rerun()
        elif res and res.status_code == 409:
            st.error("Este e-mail já está em uso por outro usuário.")
        elif res:
            st.error(detail(res))

