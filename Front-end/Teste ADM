def pagina_meu_perfil():
    st.subheader("👤 Meu Perfil")

    # Dados sempre buscados do servidor — nada armazenado no front
    dados = get(f"/usuarios/{user_id()}")
    if not dados:
        st.error("Não foi possível carregar os dados do perfil.")
        return

    with st.form("form_perfil"):
        nome = st.text_input("Nome completo", value=dados["nome"])
        email = st.text_input("Email", value=dados["email"])
        nova_senha = st.text_input(
            "Nova senha (deixe em branco para manter a atual)",
            type="password"
        )

        aviso = st.empty()

        submitted = st.form_submit_button("💾 Salvar alterações")

    # Validações fora do form para feedback imediato
    if email and not re.match(r"[^@]+@[^@]+\.[^@]+", email):
        st.warning("Digite um email válido.")

    if nova_senha:
        criterios_ok = (
            len(nova_senha) >= 8
            and re.search(r"[A-Z]", nova_senha)
            and re.search(r"[0-9]", nova_senha)
            and re.search(r"[!@#$%^&*(),.?\":{}|<>]", nova_senha)
        )
        if not criterios_ok:
            st.warning("Senha deve ter mínimo 8 chars, 1 maiúscula, 1 número e 1 caractere especial.")

    if submitted:
        payload = {
            "nome": nome,
            "email": email,
            "tipo_usuario": dados["tipo_usuario"],
        }
        if nova_senha:
            payload["senha"] = nova_senha

        res = put(f"/usuarios/{user_id()}", payload)
        if res and res.status_code == 200:
            # Atualiza apenas nome e email na sessão para refletir no sidebar
            st.session_state.usuario["nome"] = nome
            st.session_state.usuario["email"] = email
            st.success("Perfil atualizado com sucesso!")
            st.rerun()
        elif res and res.status_code == 409:
            st.error("Este email já está em uso por outro usuário.")
        elif res:
            st.error(res.json().get("detail", "Erro ao atualizar perfil."))

