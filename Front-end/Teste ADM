        st.rerun()

    st.sidebar.markdown("---")

    opcoes = ["📋 Desafios", "🏫 Cursos e Disciplinas", "👤 Meu Perfil"]
    if tipo == "professor":
        opcoes += ["➕ Criar Desafio", "✏️ Gerenciar Desafios"]

    menu = st.sidebar.radio("Navegação", opcoes)

    paginas = {
        "📋 Desafios": pagina_desafios,
        "🏫 Cursos e Disciplinas": pagina_cursos_disciplinas,
        "👤 Meu Perfil": pagina_meu_perfil,
        "➕ Criar Desafio": pagina_criar_desafio,
        "✏️ Gerenciar Desafios": pagina_gerenciar_desafios,
    }
    paginas[menu]()

