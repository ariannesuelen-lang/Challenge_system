def tela_acesso():
    st.title("🎓 Sistema Acadêmico")
    aba_login, aba_cadastro = st.tabs(["Entrar", "Cadastrar"])

    with aba_login:
        _form_login()

    with aba_cadastro:
        _form_cadastro()


def _form_login():
    st.subheader("Login")
    email = st.text_input("Email", key="login_email")
    senha = st.text_input("Senha", type="password", key="login_senha")

    if st.button("Entrar"):
        res = post("/login", {"email": email, "senha": senha})
        if res is None:
            return
        if res.status_code == 200:
            dados = res.json()
            st.session_state.logado = True
            st.session_state.usuario = dados["usuario"]
            st.success(f"Bem-vindo, {dados['usuario']['nome']}!")
            st.rerun()
        else:
            st.error(detail(res) or "Credenciais inválidas.")


def _form_cadastro():
    st.subheader("Criar conta")

    nome = st.text_input("Nome completo", key="cad_nome")
    email = st.text_input("Email", key="cad_email")
    senha = st.text_input("Senha", type="password", key="cad_senha")
    tipo = st.selectbox("Tipo de conta", ["aluno", "professor"], key="cad_tipo")

    validar_email_field(email)
    validar_senha_field(senha)

    campos_validos = (
        nome.strip()
        and email_valido(email)
        and senha_valida(senha)
    )

    aviso = st.empty()

    if st.button("Criar conta", disabled=not campos_validos):
        res = post("/usuarios", {
            "nome": nome,
            "email": email,
            "senha": senha,
            "tipo_usuario": tipo,
        })
        if res is None:
            aviso.error("Não foi possível conectar ao servidor. Tente novamente.")
        elif res.status_code == 200:
            aviso.success("Conta criada! Faça login para continuar.")
        elif res.status_code == 409:
            aviso.error("Este e-mail já está cadastrado.")
        else:
            aviso.error(detail(res) or "Erro ao criar conta.")

