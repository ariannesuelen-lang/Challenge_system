def adm_pagina_editar_usuario():
    st.subheader("✏️ Editar Usuário")

    usuarios = get("/admin/usuarios")
    if not usuarios:
        st.info("Nenhum usuário encontrado.")
        return

    # Seleção de usuário
    opcoes = {f"{u['nome']} ({u['email']})": u for u in usuarios}
    sel = st.selectbox("Selecione o usuário", list(opcoes.keys()))
    u = opcoes[sel]

    # Buscar dados atualizados
    dados = get(f"/usuarios/{u['id']}")
    if not dados:
        st.error("Erro ao carregar dados.")
        return

    st.markdown("---")

    # Formulário
    with st.form("form_editar_usuario"):
        nome = st.text_input("Nome completo", value=dados["nome"])
        email = st.text_input("Email", value=dados["email"])

        tipo = st.selectbox(
            "Tipo de usuário",
            ["aluno", "professor"],
            index=0 if dados["tipo_usuario"] == "aluno" else 1
        )

        senha = st.text_input(
            "Nova senha (opcional)",
            type="password"
        )

        submit = st.form_submit_button("💾 Salvar alterações")

    # 🔍 Validações fora do form
    if email and not re.match(r"[^@]+@[^@]+\.[^@]+", email):
        st.warning("Email inválido!")

    if senha:
        senha_ok = (
            len(senha) >= 8 and
            re.search(r"[A-Z]", senha) and
            re.search(r"[0-9]", senha) and
            re.search(r"[!@#$%^&*(),.?\":{}|<>]", senha)
        )
        if not senha_ok:
            st.warning("Senha fraca! Use 8+ chars, maiúscula, número e símbolo.")

    # 🚀 Envio
    if submit:
        payload = {
            "nome": nome,
            "email": email,
            "tipo_usuario": tipo
        }

        if senha:
            payload["senha"] = senha

        res = put(f"/usuarios/{dados['id']}", payload)

        if res and res.status_code == 200:
            st.success("Usuário atualizado com sucesso!")
            st.rerun()
        elif res and res.status_code == 409:
            st.error("Email já está em uso.")
        elif res:
            st.error(res.json().get("detail", "Erro ao atualizar usuário."))


