def adm_pagina_usuarios():
    st.subheader("👥 Gerenciar Usuários")

    usuarios = get("/admin/usuarios") or []
    if not usuarios:
        st.info("Nenhum usuário encontrado.")
        return

    # ── Filtros
    col_busca, col_filtro = st.columns([3, 2])
    with col_busca:
        busca = st.text_input("🔍 Buscar por nome ou e-mail", key="busca_user")
    with col_filtro:
        filtro_tipo = st.selectbox("Filtrar por tipo", ["Todos", "aluno", "professor"], key="filtro_tipo_user")

    filtrados = [
        u for u in usuarios
        if (busca.lower() in u["nome"].lower() or busca.lower() in u["email"].lower())
        and (filtro_tipo == "Todos" or u.get("tipo_usuario") == filtro_tipo)
    ]

    st.caption(f"{len(filtrados)} usuário(s) encontrado(s)")
    st.markdown("---")

    if not filtrados:
        st.warning("Nenhum usuário corresponde aos filtros.")
        return

    # ── Cabeçalho da tabela
    cab1, cab2, cab3, cab4 = st.columns([3, 4, 2, 1])
    cab1.markdown("**Nome**")
    cab2.markdown("**E-mail**")
    cab3.markdown("**Tipo**")
    cab4.markdown("**Ação**")
    st.markdown("---")

    for u in filtrados:
        col_nome, col_email, col_tipo, col_acao = st.columns([3, 4, 2, 1])
        with col_nome:
            st.write(u["nome"])
        with col_email:
            st.caption(u["email"])
        with col_tipo:
            st.caption(_badge_tipo(u.get("tipo_usuario", "")))
        with col_acao:
            _confirmar_delete(
                chave=f"user_{u['id']}",
                label=u["nome"],
                callback=lambda uid=u["id"]: (
                    (r := delete(f"/admin/usuarios/{uid}")) and r.status_code == 200
                ),
            )


