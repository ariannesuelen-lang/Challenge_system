def pagina_desafios():
    st.subheader("📋 Desafios")

    disciplinas = get("/disciplinas")
    opcoes_disc = {"Todas": None, **{d["nome"]: d["id"] for d in disciplinas}}
    filtro = st.selectbox("Filtrar por disciplina", list(opcoes_disc.keys()))
    disc_id = opcoes_disc[filtro]

    params = {"disciplina_id": disc_id} if disc_id else None
    desafios = get("/desafios", params=params)

    if not desafios:
        st.info("Nenhum desafio encontrado.")
        return

    for desafio in desafios:
        _card_desafio(desafio)


def _card_desafio(desafio: dict):
    titulo = f"📌 {desafio['titulo']} — {desafio.get('disciplina_nome', 'Sem disciplina')}"
    with st.expander(titulo):
        st.write(f"**Criado por:** {desafio['criador_nome']}")
        if desafio.get("descricao"):
            st.write(f"**Descrição:** {desafio['descricao']}")
        if desafio.get("data_limite"):
            st.write(f"**Prazo:** {desafio['data_limite'][:10]}")

        st.markdown("---")
        st.markdown("**💬 Respostas:**")

        respostas = get(f"/desafios/{desafio['id']}/respostas")
        if respostas:
            for r in respostas:
                _linha_resposta(r)
        else:
            st.info("Nenhuma resposta ainda. Seja o primeiro!")

        st.markdown("---")
        _form_resposta(desafio["id"])


def _linha_resposta(resposta: dict):
    col_texto, col_voto = st.columns([4, 1])
    with col_texto:
        st.write(f"👤 **{resposta['usuario_nome']}:** {resposta['conteudo']}")
    with col_voto:
        votos = resposta.get("total_votos", 0)
        if st.button(f"👍 {votos}", key=f"voto_{resposta['id']}"):
            res = post("/votos", {"resposta_id": resposta["id"], "usuario_id": user_id()})
            if res and res.status_code == 200:
                st.success("Voto registrado!")
                st.rerun()
            elif res:
                st.warning(detail(res))


def _form_resposta(desafio_id: int):
    with st.form(key=f"form_resp_{desafio_id}"):
        conteudo = st.text_area("Sua resposta", key=f"resp_{desafio_id}")
        if st.form_submit_button("Enviar resposta"):
            res = post("/respostas", {
                "desafio_id": desafio_id,
                "usuario_id": user_id(),
                "conteudo": conteudo,
            })
            if res and res.status_code == 200:
                st.success("Resposta enviada!")
                st.rerun()
            elif res:
                st.error(detail(res))


