def adm_pagina_desafios():
    st.subheader("📋 Gerenciar Desafios")

    desafios = get("/desafios") or []
    if not desafios:
        st.info("Nenhum desafio cadastrado.")
        return

    # ── Filtros
    col_busca, col_disc = st.columns([3, 2])
    with col_busca:
        busca = st.text_input("🔍 Buscar por título ou criador", key="busca_desafio")
    with col_disc:
        disciplinas = get("/disciplinas") or []
        opts_disc = {"Todas": None, **{d["nome"]: d["id"] for d in disciplinas}}
        disc_sel = st.selectbox("Filtrar por disciplina", list(opts_disc.keys()), key="filtro_disc_adm")

    filtrados = [
        d for d in desafios
        if (busca.lower() in d["titulo"].lower() or busca.lower() in d["criador_nome"].lower())
        and (opts_disc[disc_sel] is None or d.get("disciplina_id") == opts_disc[disc_sel])
    ]

    st.caption(f"{len(filtrados)} desafio(s) encontrado(s)")
    st.markdown("---")

    if not filtrados:
        st.warning("Nenhum desafio corresponde aos filtros.")
        return

    # ── Cabeçalho
    cab1, cab2, cab3, cab4 = st.columns([4, 3, 3, 1])
    cab1.markdown("**Título**")
    cab2.markdown("**Criador**")
    cab3.markdown("**Disciplina**")
    cab4.markdown("**Ação**")
    st.markdown("---")

    for d in filtrados:
        col_titulo, col_criador, col_disc2, col_acao = st.columns([4, 3, 3, 1])
        with col_titulo:
            st.write(f"**{d['titulo']}**")
        with col_criador:
            st.caption(d["criador_nome"])
        with col_disc2:
            st.caption(d.get("disciplina_nome") or "—")
        with col_acao:
            _confirmar_delete(
                chave=f"desafio_{d['id']}",
                label=d["titulo"],
                callback=lambda did=d["id"]: (
                    (r := delete(f"/admin/desafios/{did}")) and r.status_code == 200
                ),
            )

