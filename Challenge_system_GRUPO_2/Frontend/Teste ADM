                "Tipo de usuário",
                ["aluno", "professor"],
                index=0 if dados["tipo_usuario"] == "aluno" else 1,
            )
            senha  = st.text_input("Nova senha (opcional)", type="password")
            submit = st.form_submit_button("💾 Salvar alterações", use_container_width=True)

        validar_email_field(email)
        validar_senha_field(senha)

    with col_info:
        st.markdown("#### 📋 Dados atuais")
        st.write(f"**ID:** {dados['id']}")
        st.write(f"**Nome:** {dados['nome']}")
        st.write(f"**E-mail:** {dados['email']}")
        st.write(f"**Tipo:** {_badge_tipo(dados['tipo_usuario'])}")

    if submit:
        payload = {"nome": nome, "email": email, "tipo_usuario": tipo}
        if senha:
            payload["senha"] = senha
        res = put(f"/usuarios/{dados['id']}", payload)
        if res and res.status_code == 200:
            st.success("✅ Usuário atualizado com sucesso!")
            st.rerun()
        elif res and res.status_code == 409:
            st.error("E-mail já está em uso.")
        elif res:
            st.error(detail(res))

