import re
import streamlit as st
import requests

# =========================
# CONFIGURAÇÃO
# =========================

BASE_URL = "http://localhost:8000"
ADMIN_LOGIN = "admin"
ADMIN_SENHA = "Admin@1234"

REGEX_EMAIL = re.compile(r"[^@]+@[^@]+\.[^@]+")
REGEX_MAIUSCULA = re.compile(r"[A-Z]")
REGEX_NUMERO = re.compile(r"[0-9]")
REGEX_ESPECIAL = re.compile(r'[!@#$%^&*(),.?":{}|<>]')

# =========================
# INICIALIZAÇÃO DO ESTADO
# =========================

_defaults = {
    "logado": False,
    "usuario": None,
    "admin_logado": False,
    "adm_confirmar_delete": None,   # guarda (tipo, id) para confirmação
}
for chave, valor in _defaults.items():
    if chave not in st.session_state:
        st.session_state[chave] = valor

# =========================
# HELPERS DE API
# =========================

def _request(method: str, endpoint: str, body=None, params=None):
    url = f"{BASE_URL}{endpoint}"
    try:
        res = getattr(requests, method)(url, json=body, params=params)
        return res
    except requests.exceptions.ConnectionError:
        st.error("Não foi possível conectar ao servidor. Verifique se o backend está rodando.")
        return None
    except Exception as e:
        st.error(f"Erro inesperado: {e}")
        return None


def get(endpoint: str, params=None):
    res = _request("get", endpoint, params=params)
    if res is not None and res.status_code == 200:
        return res.json()
    return []


def post(endpoint: str, body: dict):
    return _request("post", endpoint, body=body)


def put(endpoint: str, body: dict, params=None):
    return _request("put", endpoint, body=body, params=params)


def delete(endpoint: str, params=None):
    return _request("delete", endpoint, params=params)


def detail(res) -> str:
    try:
        return res.json().get("detail", "Erro desconhecido.")
    except Exception:
        return "Erro desconhecido."

# =========================
# HELPERS DE SESSÃO
# =========================

def is_professor() -> bool:
    return (
        st.session_state.usuario is not None
        and st.session_state.usuario.get("tipo_usuario") == "professor"
    )


def user_id():
    if st.session_state.usuario:
        return st.session_state.usuario["id"]
    return None

# =========================
# VALIDAÇÕES
# =========================

def email_valido(email: str) -> bool:
    return bool(REGEX_EMAIL.match(email))


def senha_valida(senha: str) -> bool:
    return (
        len(senha) >= 8
        and bool(REGEX_MAIUSCULA.search(senha))
        and bool(REGEX_NUMERO.search(senha))
        and bool(REGEX_ESPECIAL.search(senha))
    )


def validar_email_field(email: str):
    if email and not email_valido(email):
        st.warning("Digite um e-mail válido.")


def validar_senha_field(senha: str):
    if senha and not senha_valida(senha):
        st.warning(
            "Senha deve ter no mínimo 8 caracteres, 1 letra maiúscula, "
            "1 número e 1 caractere especial."
        )

