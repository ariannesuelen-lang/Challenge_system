def adm_pagina_respostas():
    st.subheader("💬 Gerenciar Respostas")

    desafios = get("/desafios") or []
    if not desafios:
        st.info("Nenhum desafio encontrado.")
        return

    # Filtro por desafio
    opts = {"Todos os desafios": None, **{d["titulo"]: d["id"] for d in desafios}}
    filtro = st.selectbox("Filtrar por desafio", list(opts.keys()), key="filtro_resp_adm")

    desafios_filtrados = (
        [d for d in desafios if d["id"] == opts[filtro]]
        if opts[filtro]
        else desafios
    )

    total_exibido = 0

    for d in desafios_filtrados:
        respostas = get(f"/desafios/{d['id']}/respostas") or []
        if not respostas:
            continue

        total_exibido += len(respostas)

        with st.expander(f"📌 {d['titulo']} — {len(respostas)} resposta(s)", expanded=(opts[filtro] is not None)):
            cab1, cab2, cab3, cab4 = st.columns([2, 5, 1, 1])
            cab1.markdown("**Autor**")
            cab2.markdown("**Resposta**")
            cab3.markdown("**Votos**")
            cab4.markdown("**Ação**")
            st.markdown("---")

            for r in respostas:
                c1, c2, c3, c4 = st.columns([2, 5, 1, 1])
                with c1:
                    st.caption(r["usuario_nome"])
                with c2:
                    st.write(r["conteudo"])
                with c3:
                    st.caption(f"👍 {r.get('total_votos', 0)}")
                with c4:
                    _confirmar_delete(
                        chave=f"resp_{r['id']}",
                        label=f"resposta de {r['usuario_nome']}",
                        callback=lambda rid=r["id"]: (
                            (res := delete(f"/admin/respostas/{rid}")) and res.status_code == 200
                        ),
                    )

    if total_exibido == 0:
        st.info("Nenhuma resposta encontrada para o filtro selecionado.")

