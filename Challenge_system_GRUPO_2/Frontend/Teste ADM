def _badge_tipo(tipo: str) -> str:
    cores = {"professor": "🟣", "aluno": "🔵"}
    return f"{cores.get(tipo, '⚪')} {tipo.capitalize()}"


def _confirmar_delete(chave: str, label: str, callback):
    """
    Exibe botão de deletar com confirmação em dois cliques.
    chave  : identificador único para o estado
    label  : texto exibido no botão de confirmação
    callback: função chamada após confirmação → deve retornar (sucesso: bool)
    """
    if st.session_state.adm_confirmar_delete == chave:
        st.warning(f"⚠️ Confirmar exclusão de **{label}**?")
        col_sim, col_nao = st.columns(2)
        with col_sim:
            if st.button("✅ Confirmar", key=f"sim_{chave}"):
                ok = callback()
                st.session_state.adm_confirmar_delete = None
                if ok:
                    st.success("Removido com sucesso.")
                    st.rerun()
                else:
                    st.error("Falha ao remover.")
        with col_nao:
            if st.button("❌ Cancelar", key=f"nao_{chave}"):
                st.session_state.adm_confirmar_delete = None
                st.rerun()
    else:
        if st.button("🗑️", key=f"del_{chave}", help=f"Excluir {label}"):
            st.session_state.adm_confirmar_delete = chave
            st.rerun()

