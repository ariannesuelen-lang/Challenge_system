def _adm_aba_cursos():
    cursos = get("/cursos") or []

    # Formulário de criação no topo
    with st.expander("➕ Criar novo curso", expanded=False):
        nome_curso = st.text_input("Nome do novo curso", key="adm_curso_nome")
        if st.button("Criar Curso", key="adm_criar_curso", disabled=not nome_curso.strip()):
            res = post("/cursos", {"nome": nome_curso})
            if res and res.status_code == 200:
                st.success("Curso criado!")
                st.rerun()
            elif res:
                st.error(detail(res))

    st.markdown("---")

    if not cursos:
        st.info("Nenhum curso cadastrado.")
        return

    st.caption(f"{len(cursos)} curso(s) cadastrado(s)")

    cab1, cab2, cab3 = st.columns([1, 5, 1])
    cab1.markdown("**ID**")
    cab2.markdown("**Nome**")
    cab3.markdown("**Ação**")
    st.markdown("---")

    for c in cursos:
        col_id, col_nome, col_acao = st.columns([1, 5, 1])
        with col_id:
            st.caption(str(c["id"]))
        with col_nome:
            st.write(f"📘 {c['nome']}")
        with col_acao:
            _confirmar_delete(
                chave=f"curso_{c['id']}",
                label=c["nome"],
                callback=lambda cid=c["id"]: (
                    (r := delete(f"/admin/cursos/{cid}")) and r.status_code == 200
                ),
            )


def _adm_aba_disciplinas():
    cursos = get("/cursos") or []
    disciplinas = get("/disciplinas") or []

    # Formulário de criação no topo
    with st.expander("➕ Criar nova disciplina", expanded=False):
        if not cursos:
            st.warning("Cadastre um curso antes de criar disciplinas.")
        else:
            opts_curso = {c["nome"]: c["id"] for c in cursos}
            nome_disc  = st.text_input("Nome da nova disciplina", key="adm_disc_nome")
            curso_sel  = st.selectbox("Curso", list(opts_curso.keys()), key="adm_disc_curso")
            if st.button("Criar Disciplina", key="adm_criar_disc", disabled=not nome_disc.strip()):
                res = post("/disciplinas", {"nome": nome_disc, "curso_id": opts_curso[curso_sel]})
                if res and res.status_code == 200:
                    st.success("Disciplina criada!")
                    st.rerun()
                elif res:
                    st.error(detail(res))

    st.markdown("---")

    if not disciplinas:
        st.info("Nenhuma disciplina cadastrada.")
        return

    # Filtro por curso
    opts_filtro = {"Todos os cursos": None, **{c["nome"]: c["id"] for c in cursos}}
    filtro_curso = st.selectbox("Filtrar por curso", list(opts_filtro.keys()), key="filtro_curso_disc")
    filtradas = [
        d for d in disciplinas
        if opts_filtro[filtro_curso] is None or d.get("curso_id") == opts_filtro[filtro_curso]
    ]

    st.caption(f"{len(filtradas)} disciplina(s) encontrada(s)")
    st.markdown("---")

    cab1, cab2, cab3, cab4 = st.columns([1, 4, 4, 1])
    cab1.markdown("**ID**")
    cab2.markdown("**Nome**")
    cab3.markdown("**Curso**")
    cab4.markdown("**Ação**")
    st.markdown("---")

    for d in filtradas:
        col_id, col_nome, col_curso, col_acao = st.columns([1, 4, 4, 1])
        with col_id:
            st.caption(str(d["id"]))
        with col_nome:
            st.write(f"📗 {d['nome']}")
        with col_curso:
            st.caption(d.get("curso_nome", "—"))
        with col_acao:
            _confirmar_delete(
                chave=f"disc_{d['id']}",
                label=d["nome"],
                callback=lambda did=d["id"]: (
                    (r := delete(f"/admin/disciplinas/{did}")) and r.status_code == 200
                ),
            )


def adm_pagina_cursos():
    st.subheader("🏫 Cursos e Disciplinas")
    aba_cursos, aba_disciplinas = st.tabs(["📘 Cursos", "📗 Disciplinas"])
    with aba_cursos:
